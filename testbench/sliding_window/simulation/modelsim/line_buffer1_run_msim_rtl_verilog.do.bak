transcript on
if {[file exists rtl_work]} {
	vdel -lib rtl_work -all
}
vlib rtl_work
vmap work rtl_work

vlog -vlog01compat -work work +incdir+E:/2_Intern_PTIT/testbench {E:/2_Intern_PTIT/testbench/line_buffer1.v}

vlog -vlog01compat -work work +incdir+E:/2_Intern_PTIT/testbench {E:/2_Intern_PTIT/testbench/tb_line_buffer1.v}

vsim -t 1ps -L altera_ver -L lpm_ver -L sgate_ver -L altera_mf_ver -L altera_lnsim_ver -L fiftyfivenm_ver -L rtl_work -L work -voptargs="+acc"  tb_line_buffer1

add wave *
view structure
view signals
run -all
